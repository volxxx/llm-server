#!/bin/bash
# shellcheck disable=SC1090,SC2001
#
# llm-server-gui — Terminal model selector for llm-server
# Lists available GGUF models and launches llm-server with the selected one.
# After selecting a model, toggle options with keyboard shortcuts before launch.
#
# Usage:
#   llm-server-gui                    # Select from configured model dir
#   llm-server-gui --model-dir /path  # Custom model directory
#   llm-server-gui --model /path/to/model.gguf  # Launch specific model
#   llm-server-gui -h|--help          # Show this help message
#
# Interactive options (after model selection):
#   [a] AI Tune    — Run AI-driven flag optimization (8 rounds)
#   [b] Benchmark  — Start, run quick benchmark, print tok/s
#   [v] Vision     — Auto-detect/download mmproj for multimodal
#   [o] OpenCode   — Launch OpenCode after server is healthy
#   [d] Dry Run    — Print command without executing
#   [Enter]        — Launch with defaults (skip all options)
#
# All llm-server flags can also be passed directly:
#   llm-server-gui --benchmark
#   llm-server-gui --model ~/models/Qwen3.5.gguf --ai-tune
#   llm-server-gui --gpus 0,1 --port 8082
#
# Environment:
#   LLM_MODEL_DIR   Default search path (default: ~/ai_models)
#

set -euo pipefail

CONFIG_DIR="$HOME/.config/llm-server"
CONFIG_FILE="$CONFIG_DIR/config.sh"
mkdir -p "$CONFIG_DIR"

# Load persistent config
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

MODEL_DIR="${LLM_MODEL_DIR:-$HOME/ai_models}"
SPECIFIC_MODEL=""

# Backend preference (ik_llama or llama)
PREFERRED_BACKEND="${LLM_BACKEND:-llama}"  # default to llama

# Auto-detect platform and use correct launcher
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [[ "$(uname -s)" == "Darwin" ]]; then
    LAUNCHER="$SCRIPT_DIR/llm-server-mac"
    [[ ! -x "$LAUNCHER" ]] && LAUNCHER="$SCRIPT_DIR/llm-server"
else
    LAUNCHER="$SCRIPT_DIR/llm-server"
fi

# Check if backends exist
IK_BACKEND="$HOME/ik_llama.cpp/build/bin/llama-server"
LLAMA_BACKEND="$HOME/llama.cpp/build/bin/llama-server"

# Check for updates (same logic as llm-server - works in GUI too with TTY)
LLM_SERVER_REPO="${LLM_SERVER_REPO:-$HOME/llm-server}"
CACHE_DIR="$HOME/.cache/llm-server"
UPDATE_DISMISS_FILE="$CACHE_DIR/update_dismissed"
UPDATE_DISMISS_DAYS=7

_check_repo_behind() {
    local repo_dir="$1" label="$2"
    [[ -d "$repo_dir/.git" ]] || return 1
    # Fetch latest from origin
    git -C "$repo_dir" fetch origin --quiet 2>/dev/null &
    local fetch_pid=$!
    ( sleep 3; kill "$fetch_pid" 2>/dev/null ) &
    wait "$fetch_pid" 2>/dev/null || true
    
    local local_head remote_head
    local_head=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null) || return 1
    # Try origin/main first, then origin/master
    remote_head=$(git -C "$repo_dir" rev-parse origin/main 2>/dev/null) || remote_head=$(git -C "$repo_dir" rev-parse origin/master 2>/dev/null) || return 1
    [[ "$local_head" != "$remote_head" ]] && echo "$label" && return 0
    return 1
}

_should_check_updates() {
    if [[ -f "$UPDATE_DISMISS_FILE" ]]; then
        local dismissed_at
        dismissed_at=$(cat "$UPDATE_DISMISS_FILE" 2>/dev/null)
        local now
        now=$(date +%s)
        if (( now - dismissed_at < UPDATE_DISMISS_DAYS * 86400 )); then
            return 1
        fi
    fi
    return 0
}

if _should_check_updates && [[ -d "$LLM_SERVER_REPO/.git" ]]; then
    _updates=()
    _check_repo_behind "$LLM_SERVER_REPO" "llm-server" && _updates+=("llm-server")
    [[ -x "$IK_BACKEND" ]] && _check_repo_behind "$HOME/ik_llama.cpp" "ik_llama.cpp" && _updates+=("ik_llama.cpp")
    [[ -x "$LLAMA_BACKEND" ]] && _check_repo_behind "$HOME/llama.cpp" "llama.cpp" && _updates+=("llama.cpp")

    if (( ${#_updates[@]} > 0 )); then
        echo "═══ Updates Available ═══"
        echo "  ⚠ ${_updates[*]}"
        echo ""
        # Try to get input - prefer /dev/tty if available, else use stdin
        if [[ -t 0 ]] || [[ -t 1 ]]; then
            # Terminal mode - use stdin directly
            read -r -p "  Update now? [y/N/d=dismiss ${UPDATE_DISMISS_DAYS} days] " _answer
        else
            # Pipe mode - try tty, if fail use echo as fallback
            _answer=$(echo "" | head -1)  # Just skip for piped input
            echo "  (skipped in piped mode - run in terminal for interactive update)"
            _answer="n"
        fi
        case "${_answer,,}" in
            y)
                echo "  Running --update..."
                exec "$SCRIPT_DIR/llm-server" --update
                ;;
            d)
                mkdir -p "$CACHE_DIR"
                date +%s > "$UPDATE_DISMISS_FILE"
                echo "  Dismissed for ${UPDATE_DISMISS_DAYS} days."
                echo ""
                ;;
            *)
                echo "  Skipped."
                echo ""
                ;;
        esac
    fi
fi

# Help flag
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    sed -n '4,/^$/s/^# \?//p' "$0"
    exit 0
fi

# Parse args (pass through to llm-server)
PASSTHROUGH_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --model-dir) MODEL_DIR="$2"; shift 2 ;;
        --model) SPECIFIC_MODEL="$2"; shift 2 ;;
        *)           PASSTHROUGH_ARGS+=("$1"); shift ;;
    esac
done

# First-run setup: If default dir is empty/missing, ask user
if [[ ! -d "$MODEL_DIR" || -z "$(ls -A "$MODEL_DIR" 2>/dev/null)" ]]; then
    echo "═══ llm-server First Run Setup ═══"
    echo "No models found in: $MODEL_DIR"
    echo ""
    read -rp "Enter the full path to your model directory: " USER_PATH
    
    # Expand tilde if present
    USER_PATH="${USER_PATH/#\~/$HOME}"
    
    if [[ -d "$USER_PATH" ]]; then
        echo "LLM_MODEL_DIR=\"$USER_PATH\"" > "$CONFIG_FILE"
        MODEL_DIR="$USER_PATH"
        echo "✓ Path saved to $CONFIG_FILE"
    else
        echo "Error: Directory not found: $USER_PATH"
        exit 1
    fi
fi

# If a specific model is provided, launch directly without TUI
if [[ -n "$SPECIFIC_MODEL" ]]; then
    if [[ ! -f "$SPECIFIC_MODEL" ]]; then
        echo "Error: Model not found: $SPECIFIC_MODEL"
        exit 1
    fi
    exec "$LAUNCHER" "${PASSTHROUGH_ARGS[@]}" "$SPECIFIC_MODEL"
fi

if [[ ! -d "$MODEL_DIR" ]]; then
    echo "Error: Model directory not found: $MODEL_DIR"
    exit 1
fi

if [[ ! -x "$LAUNCHER" ]]; then
    echo "Error: llm-server not found at $LAUNCHER"
    exit 1
fi

# Backend selection
echo "═══ Select Backend ═══"
echo "  [1] llama.cpp       — better stability (recommended for production)"
echo "  [2] ik_llama.cpp   — better performance (experimental features)"
echo ""
ik_avail=0; llama_avail=0
[[ -x "$IK_BACKEND" ]] && ik_avail=1
[[ -x "$LLAMA_BACKEND" ]] && llama_avail=1

# If only one is available, auto-select
backend_choice=1
if (( ik_avail )) && (( ! llama_avail )); then
    backend_choice=2
elif (( ! ik_avail )) && (( llama_avail )); then
    backend_choice=1
else
    read -rp "Choice [1]: " backend_choice
    backend_choice=${backend_choice:-1}
fi

if (( backend_choice == 2 )) && (( ik_avail )); then
    PREFERRED_BACKEND="ik_llama"
    if grep -q "LLM_BACKEND" "$CONFIG_FILE" 2>/dev/null; then
        sed -i "s|LLM_BACKEND=.*|LLM_BACKEND=\"ik_llama\"|" "$CONFIG_FILE"
    else
        echo 'LLM_BACKEND="ik_llama"' >> "$CONFIG_FILE"
    fi
else
    PREFERRED_BACKEND="llama"
    if grep -q "LLM_BACKEND" "$CONFIG_FILE" 2>/dev/null; then
        sed -i 's|LLM_BACKEND=.*|LLM_BACKEND="llama"|' "$CONFIG_FILE"
    else
        echo 'LLM_BACKEND="llama"' >> "$CONFIG_FILE"
    fi
fi
echo "  Using: $PREFERRED_BACKEND"
echo ""

# Find GGUF models (show first file of split GGUFs, skip duplicates)
declare -a MODEL_PATHS MODEL_DISPLAY
idx=0

while IFS= read -r file; do
    basename=$(basename "$file")
    # Skip split GGUF parts that aren't the first file
    if [[ "$basename" =~ -[0-9]+-of-[0-9]+\.gguf$ ]]; then
        [[ ! "$basename" =~ -00001-of-[0-9]+\.gguf$ ]] && continue
    fi

    # Get total size (including all split parts)
    dir=$(dirname "$file")
    pattern=$(echo "$basename" | sed 's/-[0-9]*-of-[0-9]*\.gguf/.gguf/')
    # Calculate total bytes (cross-platform: macOS stat -f%z, Linux stat --printf)
    total_bytes=0
    while IFS= read -r part; do
        sz=$(stat -f%z "$part" 2>/dev/null || stat --printf="%s" "$part" 2>/dev/null || echo 0)
        total_bytes=$(( total_bytes + sz ))
    done < <(find "$dir" -name "${pattern%.gguf}*" -type f 2>/dev/null)
    (( total_bytes == 0 )) && total_bytes=$(stat -f%z "$file" 2>/dev/null || stat --printf="%s" "$file" 2>/dev/null || echo 0)
    size_gb=$(awk "BEGIN {printf \"%.1f\", $total_bytes/1073741824}")

    # Detect MoE from filename patterns (A3B, A10B, etc.)
    arch="dense"
    [[ "$basename" =~ A[0-9]+B ]] && arch="MoE"

    MODEL_PATHS+=("$file")
    MODEL_DISPLAY+=("$basename (${size_gb}GB, $arch)")
    idx=$(( idx + 1 ))
done < <(find "$MODEL_DIR" -name "*.gguf" -type f 2>/dev/null | sort)

if (( idx == 0 )); then
    echo "No GGUF models found in $MODEL_DIR"
    exit 1
fi

# Display menu
echo ""
echo "═══ Available Models ═══"
echo ""
for i in $(seq 0 $(( idx - 1 ))); do
    printf "  %2d. %s\n" "$((i+1))" "${MODEL_DISPLAY[$i]}"
done
echo ""

# Read selection
while true; do
    read -rp "Select model (1-$idx, q to quit): " choice
    [[ "$choice" == "q" || "$choice" == "Q" ]] && exit 0
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= idx )); then
        break
    fi
    echo "Invalid choice."
done

SELECTED="${MODEL_PATHS[$((choice-1))]}"
echo ""

# Option toggles (skip with Enter)
OPT_FLAGS=()
echo "Options (toggle with letter, Enter to launch):"
opt_aitune=0; opt_bench=0; opt_vision=0; opt_opencode=0; opt_dryrun=0; opt_keepalive=0
opt_rounds=8  # default rounds for AI Tune
print_opts() {
    local a="off" b="off" v="off" o="off" d="off" k="off"
    (( opt_aitune )) && a="ON"
    (( opt_bench )) && b="ON"
    (( opt_vision )) && v="ON"
    (( opt_opencode )) && o="ON"
    (( opt_dryrun )) && d="ON"
    (( opt_keepalive )) && k="ON"
    printf "  [a] AI Tune %-3s  [b] Bench %-3s  [v] Vision %-3s  [o] OpenCode %-3s  [d] DryRun %-3s  [k] KeepAlive %-3s\r" "$a" "$b" "$v" "$o" "$d" "$k"
}
print_opts
while true; do
    read -rsn1 key
    case "$key" in
        a|A) (( opt_aitune = !opt_aitune )) || true ;;
        b|B) (( opt_bench = !opt_bench )) || true ;;
        v|V) (( opt_vision = !opt_vision )) || true ;;
        o|O) (( opt_opencode = !opt_opencode )) || true ;;
        d|D) (( opt_dryrun = !opt_dryrun )) || true ;;
        k|K) (( opt_keepalive = !opt_keepalive )) || true ;;
        "") break ;;
        *) continue ;;
    esac
    printf "\r%150s\r" ""
    print_opts
done
echo ""

# After options, if AI Tune is on, ask for rounds + unlimited in a new "window"
opt_unlimited=0
if (( opt_aitune )); then
    echo "═══ AI Tune Options ═══"
    read -rp "  Enable UNLIMITED (deep) mode? [y/N] " unl_ans
    case "${unl_ans,,}" in y|yes) opt_unlimited=1 ;; esac
    default_rounds=8
    (( opt_unlimited )) && default_rounds=20
    read -rp "  Number of rounds (1-30, default ${default_rounds}): " new_rounds
    opt_rounds=${new_rounds:-$default_rounds}
    [[ ! "$opt_rounds" =~ ^[0-9]+$ ]] && opt_rounds=$default_rounds
    (( opt_rounds < 1 )) && opt_rounds=1
    (( opt_rounds > 30 )) && opt_rounds=30
    echo "  Rounds: $opt_rounds  Unlimited: $(( opt_unlimited ? 1 : 0 ))"
    echo ""
fi

(( opt_aitune )) && OPT_FLAGS+=(--ai-tune)
(( opt_unlimited )) && OPT_FLAGS+=(--unlimited)
(( opt_aitune && opt_rounds != 8 && opt_unlimited == 0 )) && OPT_FLAGS+=(--rounds "$opt_rounds")
(( opt_aitune && opt_unlimited && opt_rounds != 20 )) && OPT_FLAGS+=(--rounds "$opt_rounds")
(( opt_bench )) && OPT_FLAGS+=(--benchmark)
(( opt_vision )) && OPT_FLAGS+=(--vision)
(( opt_opencode )) && OPT_FLAGS+=(--opencode)
(( opt_dryrun )) && OPT_FLAGS+=(--dry-run)
(( opt_keepalive )) && OPT_FLAGS+=(--keep-alive)

echo "Launching: $(basename "$SELECTED") ${OPT_FLAGS[*]:-}"
echo ""

# Add server-bin based on backend preference
if [[ "$PREFERRED_BACKEND" == "ik_llama" ]]; then
    SERVER_BIN_FLAG=(--server-bin "$IK_BACKEND")
else
    SERVER_BIN_FLAG=(--server-bin "$LLAMA_BACKEND")
fi

# Pass env to skip update check (already done in GUI)
export LLM_SERVER_UPDATE_CHECKED=1

exec "$LAUNCHER" "${SERVER_BIN_FLAG[@]}" "${PASSTHROUGH_ARGS[@]}" "${OPT_FLAGS[@]+"${OPT_FLAGS[@]}"}" "$SELECTED"
