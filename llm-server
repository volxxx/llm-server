# Build -ot string from array of (cuda_device, layer_start, layer_count) assignments
# Args: pairs of "CUDA_INDEX LAYER_START LAYER_COUNT" followed by end marker
build_ot_string() {
    local parts=()
    # Fused models use different tensor names for experts
    local up_gate_pattern="ffn_(gate|up|down)_exps"
    if (( HAS_FUSED == 1 )); then
        up_gate_pattern="ffn_(up_gate|down)_exps"
    fi

    while [[ $# -ge 3 ]]; do
        local cuda_idx=$1 layer_start=$2 layer_count=$3
        shift 3
        if (( layer_count > 0 )); then
            local last=$(( layer_start + layer_count - 1 ))
            local re=$(seq "$layer_start" "$last" | tr '\n' '|' | sed 's/|$//')
            parts+=("blk\\.(${re})\\.${up_gate_pattern}.*=CUDA${cuda_idx}")
        fi
    done
    parts+=("exps=CPU")
    local IFS=,
    echo "${parts[*]}"
}

kill_server() {
    local pid=${1:-}
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null
        wait "$pid" 2>/dev/null || true
    fi
    # Aggressive port cleanup
    local port_pids
    port_pids=$(lsof -t -i:"${PORT}" 2>/dev/null) || true
    if [[ -n "$port_pids" ]]; then
        kill -9 $port_pids 2>/dev/null || true
    fi
    local w=0
    while (( w < 10 )); do
        lsof -i:"${PORT}" >/dev/null 2>&1 || break
        sleep 1; (( w++ ))
    done
    sleep 2
}

# Try starting server, wait for health. Sets RUNNING_PID on success.
RUNNING_PID=""
try_start() {
    local extra_flags=("$@")
    RUNNING_PID=""
    # Use process substitution to get the REAL pid of the server, not the tee pid
    "$LLAMA_SERVER" "${COMMON_FLAGS[@]}" "${extra_flags[@]}" > >(tee -a "$SERVER_LOG") 2>&1 &
    local pid=$!
    local i=0
    while (( i < 240 )); do
        if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
            RUNNING_PID=$pid
            return 0
        fi
        if ! kill -0 "$pid" 2>/dev/null; then
            return 1
        fi
        sleep 1; (( i++ ))
    done
    kill -9 "$pid" 2>/dev/null; wait "$pid" 2>/dev/null || true
    return 1
}

print_cmd() {
    echo ""
    echo "Command:"
    local line="  $LLAMA_SERVER"
    local args=("$@")
    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        # Pair --flag with its value (next arg that doesn't start with -)
        if [[ "$arg" == -* ]] && (( i + 1 < ${#args[@]} )) && [[ "${args[$((i+1))]}" != -* ]]; then
            local pair="$arg ${args[$((i+1))]}"
            i=$(( i + 1 ))
        else
            local pair="$arg"
        fi
        # Wrap lines at ~80 chars
        if (( ${#line} + ${#pair} + 1 > 80 )); then
            echo "$line \\"
            line="    $pair"
        else
            line="$line $pair"
        fi
    done
    echo "$line"
}

# Run benchmark: send a prompt, measure tok/s
run_benchmark() {
    local url="http://127.0.0.1:${PORT}"
    echo ""
    echo "═══ Benchmark ═══"

    # Prompt processing benchmark (short prompt)
    local pp_prompt="Explain the theory of relativity in simple terms. Cover special and general relativity, time dilation, and gravitational effects."
    local result
    result=$(curl -sf "$url/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"model\":\"test\",\"messages\":[{\"role\":\"user\",\"content\":\"$pp_prompt\"}],\"max_tokens\":200,\"temperature\":0.1}" 2>/dev/null)

    if [[ -z "$result" ]]; then
        echo "Benchmark failed — server not responding"
        return 1
    fi

    local pp_tokens pp_time tg_tokens tg_time
    pp_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(u.get('prompt_tokens',0))" 2>/dev/null)
    tg_tokens=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); u=d.get('usage',{}); print(u.get('completion_tokens',0))" 2>/dev/null)

    # Use timings endpoint if available (ik_llama.cpp / llama.cpp specific)
    local timings
    timings=$(curl -sf "$url/slots" 2>/dev/null)
    if [[ -n "$timings" ]]; then
        local pp_rate tg_rate
        # Improved extraction from slot timings
        pp_rate=$(echo "$timings" | python3 -c "
import sys,json
d=json.load(sys.stdin)
s=d[0] if isinstance(d,list) else d
t_pp = s.get('t_prompt_processing', 0)
n_pp = s.get('n_prompt_tokens_processed', 1)
if t_pp > 0: print(f\"{n_pp / (t_pp / 1000):.1f}\")
else: print('?')
" 2>/dev/null)
        tg_rate=$(echo "$timings" | python3 -c "
import sys,json
d=json.load(sys.stdin)
s=d[0] if isinstance(d,list) else d
t_gen = s.get('t_token_generation', 0)
n_gen = s.get('n_decoded', 1)
if t_gen > 0: print(f\"{n_gen / (t_gen / 1000):.1f}\")
else: print('?')
" 2>/dev/null)
        echo "  Prompt processing: ${pp_tokens:-?} tokens @ ${pp_rate:-?} tok/s"
        echo "  Generation:        ${tg_tokens:-?} tokens @ ${tg_rate:-?} tok/s"
    else
        echo "  Prompt tokens: ${pp_tokens:-?}"
        echo "  Generated tokens: ${tg_tokens:-?}"
        echo "  (Install ik_llama.cpp for detailed timing)"
    fi
    echo ""
    # Auto-exit after benchmark to prevent "hanging"
    echo "Benchmark complete. Shutting down server..."
    kill_server ""
    exit 0
}

# Suggest alternatives when model doesn't fit
suggest_alternatives() {
    local model_mb=$1
    local available_mb=$2
    echo ""
    echo "═══ Model doesn't fit ═══"
    echo "  Model needs: ~${model_mb}MB (with overhead)"
    echo "  Available:   ~${available_mb}MB (GPU + RAM)"
    echo ""
    echo "  Options:"
    echo "  1. Use a smaller quantization (e.g., Q4 → IQ3, IQ3 → IQ2)"
    echo "  2. Reduce context size: --ctx-size 16384 or --ctx-size 8192"
    echo "  3. Use a smaller model (fewer parameters or MoE with fewer active)"
    if (( GPU_COUNT > 0 )); then
        echo "  4. Add more RAM (cheapest upgrade for MoE expert offload)"
    else
        echo "  4. Add a GPU (even a used RTX 3060 12GB helps significantly)"
    fi
    echo ""
}

# Run server with automatic crash restart and backoff
# Args: all flags to pass to llama-server
MAX_RESTARTS=5
run_with_restart() {
    local flags=("$@")
    local restarts=0
    local last_start=0

    while true; do
        last_start=$(date +%s)
        echo "Starting server (PID will follow)..."
        "$LLAMA_SERVER" "${flags[@]}" 2>&1 | tee "$SERVER_LOG" | grep -v --line-buffered "record AND rewind is invalid" &
        local pid=$!
        echo "Server PID: $pid"

        # Wait for health before declaring success
        local healthy=0
        for i in $(seq 1 240); do
            if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
                healthy=1
                break
            fi
            if ! kill -0 "$pid" 2>/dev/null; then
                break
            fi
            sleep 1
        done

        if (( healthy )); then
            echo "Server healthy."
            if (( BENCHMARK )); then
                run_benchmark
                BENCHMARK=0  # only run once
            fi
            restarts=0  # reset counter on successful start
            wait "$pid" 2>/dev/null || true
            local exit_code=$?
        else
            echo "Server failed to become healthy."
            kill -9 "$pid" 2>/dev/null; wait "$pid" 2>/dev/null || true
            local exit_code=1
        fi

        # Server exited — decide whether to restart
        local uptime=$(( $(date +%s) - last_start ))

        # Clean exit (signal 0 or SIGTERM)
        if (( exit_code == 0 || exit_code == 143 )); then
            echo "Server exited cleanly (code $exit_code). Not restarting."
            exit 0
        fi

        restarts=$(( restarts + 1 ))
        echo ""
        echo "═══ Server crashed (exit code $exit_code, uptime ${uptime}s) ═══"
        tail -5 "$SERVER_LOG" 2>/dev/null
        echo ""

        if (( restarts > MAX_RESTARTS )); then
            echo "Too many restarts ($MAX_RESTARTS). Giving up."
            echo "Check $SERVER_LOG for details."
            exit 1
        fi

        # Backoff: 2s, 4s, 8s, 16s, 32s
        local wait_sec=$(( 2 ** restarts ))
        (( wait_sec > 30 )) && wait_sec=30

        # If server ran for >60s, it was a runtime crash (not startup OOM)
        # Reset backoff since the config itself works
        if (( uptime > 60 )); then
            wait_sec=2
            # Still count runtime crashes — don't loop forever
            echo "Runtime crash (ran ${uptime}s). Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."
        else
            echo "Startup crash. Restart $restarts/$MAX_RESTARTS in ${wait_sec}s..."
        fi

        sleep "$wait_sec"

        # Clean up port before restart
        kill_server ""
    done
}

# ═══════════════════════════════════════════════════════════════
# Section 7: Execute Strategy
# ═══════════════════════════════════════════════════════════════

# Kill any existing server on this port
kill_server ""

case "$STRATEGY" in
    cpu_only)
        if (( CPU_ONLY )); then
            echo "Running on CPU only (forced via --cpu)"
        else
            echo "Running on CPU only (no GPUs detected)"
        fi
        # CPU-optimized: smaller batches, no GPU flags, mlock for hugepages
        LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" -ngl 0 --no-mmap --mlock -b 512 -ub 256)
        # Strip GPU-only flags from COMMON_FLAGS
        clean_flags=()
        skip_next=0
        for f in "${LAUNCH_FLAGS[@]}"; do
            if (( skip_next )); then skip_next=0; continue; fi
            case "$f" in
                -ngl|-mg|--split-mode|--tensor-split|-b|-ub) skip_next=1; continue ;;
                --run-time-repack|-muge|-ger) continue ;;
                *) clean_flags+=("$f") ;;
            esac
        done
        LAUNCH_FLAGS=("${clean_flags[@]}" -ngl 0 -b 512 -ub 256)
        if (( DRY_RUN )); then
            print_cmd "${LAUNCH_FLAGS[@]}"
            exit 0
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
        ;;

    single_gpu)
        local_best=${GPU_ORDER[0]}
        echo "Model fits on GPU${GPU_INDEX[$local_best]} (${GPU_NAME[$local_best]})"
        LAUNCH_FLAGS=("${COMMON_FLAGS[@]}")
        if (( DRY_RUN )); then
            print_cmd "${LAUNCH_FLAGS[@]}"
            exit 0
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
        ;;

    multi_gpu_dense)
        echo "Dense model split across $GPU_COUNT GPUs"
        # Build tensor-split proportional to free VRAM weighted by bandwidth
        total_weighted=0
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            (( total_weighted += GPU_VRAM_FREE[$i] * GPU_BANDWIDTH[$i] )) || true
        done
        TS=""
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            w=$(awk "BEGIN {printf \"%.2f\", ${GPU_VRAM_FREE[$i]} * ${GPU_BANDWIDTH[$i]} / $total_weighted}")
            TS="${TS:+$TS,}$w"
        done
        echo "Tensor split: $TS"
        
        # Prefer graph split for both backends if more than 1 GPU
        GRAPH_EXTRA=(--split-mode graph --tensor-split "$TS")
        
        if (( IS_IK_LLAMA )); then
            LAYER_EXTRA=(--split-mode layer --tensor-split "$TS")
            if (( DRY_RUN )); then
                print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                exit 0
            fi
            echo "Trying graph split (fastest)..."
            if try_start "${GRAPH_EXTRA[@]}"; then
                echo "  Graph split works — restarting with crash recovery..."
                kill_server "$RUNNING_PID"
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                echo "  Graph split failed — retrying with NCCL_P2P_DISABLE=1..."
                kill_server ""
                export NCCL_P2P_DISABLE=1
                if try_start "${GRAPH_EXTRA[@]}"; then
                    echo "  Graph split works with P2P disabled — restarting with crash recovery..."
                    kill_server "$RUNNING_PID"
                    run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                else
                    echo "  Graph split unavailable — falling back to layer split"
                    kill_server ""
                    unset NCCL_P2P_DISABLE
                    run_with_restart "${COMMON_FLAGS[@]}" "${LAYER_EXTRA[@]}"
                fi
            fi
        else
            # Mainline llama.cpp
            if (( DRY_RUN )); then
                print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                exit 0
            fi
            # Test if mainline supports graph mode
            if timeout 5 "$LLAMA_SERVER" --help 2>&1 | grep -q "graph" 2>/dev/null; then
                echo "Mainline supports graph mode — attempting launch..."
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                # Fallback to row split (classic mainline multi-GPU)
                LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --split-mode row --tensor-split "$TS")
                run_with_restart "${LAUNCH_FLAGS[@]}"
            fi
        fi
        ;;

    dense_cpu_offload)
        echo "Dense model with CPU offload"
        if (( GPU_COUNT > 1 )); then
            GRAPH_EXTRA=(--split-mode graph --no-mmap)
            if (( IS_IK_LLAMA )); then
                # (ik_llama specific graph logic already handled above or can be simplified here)
                if (( DRY_RUN )); then print_cmd "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"; exit 0; fi
                run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
            else
                # Mainline
                if timeout 5 "$LLAMA_SERVER" --help 2>&1 | grep -q "graph" 2>/dev/null; then
                    run_with_restart "${COMMON_FLAGS[@]}" "${GRAPH_EXTRA[@]}"
                else
                    run_with_restart "${COMMON_FLAGS[@]}" --no-mmap
                fi
            fi
        else
            LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --no-mmap)
            if (( DRY_RUN )); then
                print_cmd "${LAUNCH_FLAGS[@]}"
                exit 0
            fi
            run_with_restart "${LAUNCH_FLAGS[@]}"
        fi
        ;;

    moe_offload)
        # Falls through to the MoE tuning section below
        ;;
esac

# ═══════════════════════════════════════════════════════════════
# Section 8: MoE Expert Placement & Auto-Tuning
# ═══════════════════════════════════════════════════════════════

mkdir -p "$CACHE_DIR"
CACHE_KEY=$(echo "${MODEL_NAME}_${TOTAL_SIZE_BYTES}" | md5sum | awk '{print $1}')
CACHE_FILE="$CACHE_DIR/${CACHE_KEY}.conf"

# Estimate per-layer expert size (~90% of model is experts in MoE)
EXPERT_TOTAL_MB=$(awk "BEGIN {printf \"%.0f\", $TOTAL_SIZE_MB * 0.90}")
EXPERT_PER_LAYER_MB=$(awk "BEGIN {printf \"%.0f\", $EXPERT_TOTAL_MB / $LAYER_COUNT}")
echo "Expert size per layer: ~${EXPERT_PER_LAYER_MB}MB"

# Total KV cache size (model-specific, used for VRAM budgeting)
if [[ "$KV_TYPE" == "q8_0" ]]; then
    KV_TOTAL_MB=$KV_Q8_MB
else
    KV_TOTAL_MB=$KV_Q4_MB
fi

# Check cached config
if [[ -f "$CACHE_FILE" && "$RETUNE" == "0" ]]; then
    echo ""
    echo "Using cached config: $CACHE_FILE"
    source "$CACHE_FILE"

    # Validate cached config against current VRAM
    CACHE_VALID=1
    OT_ARGS=()
    for assignment in $CACHED_GPU_ASSIGNMENTS; do
        IFS=: read -r ci cs cc <<< "$assignment"
        OT_ARGS+=("$ci" "$cs" "$cc")
        # Check this GPU has enough VRAM for assigned layers + its share of KV cache
        layer_mb=$(( cc * EXPERT_PER_LAYER_MB ))
        kv_share_mb=$(( KV_TOTAL_MB * cc / LAYER_COUNT + 512 ))  # proportional KV + compute
        needed=$(( layer_mb + kv_share_mb ))
        # Find free VRAM for this CUDA index
        for gi in $(seq 0 $(( GPU_COUNT - 1 ))); do
            if [[ "${GPU_INDEX[$gi]}" == "$ci" ]]; then
                if (( needed > GPU_VRAM_FREE[$gi] )); then
                    echo "  WARNING: GPU${ci} needs ${needed}MB but only ${GPU_VRAM_FREE[$gi]}MB free"
                    CACHE_VALID=0
                fi
                break
            fi
        done
        echo "  GPU${ci}: ${cc} layers (starting at block ${cs})"
    done

    if (( CACHE_VALID )); then
        OT_STRING=$(build_ot_string "${OT_ARGS[@]}")
        LAUNCH_FLAGS=("${COMMON_FLAGS[@]}" --no-mmap -ot "$OT_STRING")
        if (( DRY_RUN )); then
            print_cmd "${LAUNCH_FLAGS[@]}"
            exit 0
        fi
        run_with_restart "${LAUNCH_FLAGS[@]}"
    else
        echo "  Cached config invalid for current VRAM — retuning..."
        rm -f "$CACHE_FILE"
    fi
fi

# Calculate initial conservative placement
# Budget: GPUs get decreasing % based on priority (fastest gets most headroom for compute)
# Reserve VRAM on primary GPU for KV cache + batch buffers + compute scratch
declare -a LAYERS_PER_GPU
BUDGET_PCTS=(70 55 50 45 40 35 30 25)  # Decreasing budget for lower-priority GPUs
NEXT_LAYER=0
TOTAL_GPU_LAYERS=0

# Per-GPU VRAM budget: subtract proportional KV cache + compute overhead per layer
# KV cache is split across GPUs proportionally to layers placed on each
# Formula: each layer on a GPU costs EXPERT_PER_LAYER_MB + KV_PER_LAYER_MB + compute
KV_PER_LAYER_MB=$(( KV_TOTAL_MB / LAYER_COUNT ))
COMPUTE_PER_GPU_MB=512  # compute buffers + CUDA context per GPU
COST_PER_LAYER_MB=$(( EXPERT_PER_LAYER_MB + KV_PER_LAYER_MB ))
echo "  Per-layer cost: ${EXPERT_PER_LAYER_MB}MB experts + ${KV_PER_LAYER_MB}MB KV = ${COST_PER_LAYER_MB}MB"

for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
    gi=${GPU_ORDER[$i]}
    pct=${BUDGET_PCTS[$i]:-20}
    available_mb=$(( GPU_VRAM_FREE[$gi] - COMPUTE_PER_GPU_MB ))
    (( available_mb < 0 )) && available_mb=0
    budget_mb=$(( available_mb * pct / 100 ))
    layers=0
    if (( COST_PER_LAYER_MB > 0 )); then
        layers=$(( budget_mb / COST_PER_LAYER_MB ))
    fi
    # Cap to remaining layers
    remain=$(( LAYER_COUNT - NEXT_LAYER ))
    (( layers > remain )) && layers=$remain
    LAYERS_PER_GPU[$gi]=$layers
    NEXT_LAYER=$(( NEXT_LAYER + layers ))
    TOTAL_GPU_LAYERS=$(( TOTAL_GPU_LAYERS + layers ))
done

LAYERS_CPU=$(( LAYER_COUNT - TOTAL_GPU_LAYERS ))

# RAM safety check
CPU_EXPERT_MB=$(( LAYERS_CPU * EXPERT_PER_LAYER_MB ))
if (( HEAD_COUNT_KV > 0 && KEY_LENGTH > 0 && VALUE_LENGTH > 0 )); then
    KV_CACHE_MB=$(awk "BEGIN {printf \"%.0f\", $CTX_SIZE * $LAYER_COUNT * $HEAD_COUNT_KV * ($KEY_LENGTH + $VALUE_LENGTH) * 0.5 / 1048576}")
else
    KV_CACHE_MB=$(( LAYER_COUNT * 70 ))
fi
RAM_NEEDED=$(( CPU_EXPERT_MB + KV_CACHE_MB + 5120 ))

ACTUAL_CTX=$CTX_SIZE
if (( RAM_NEEDED > RAM_AVAIL_MB )); then
    for try_ctx in 32768 16384 8192 4096; do
        kv_at_ctx=$(( KV_CACHE_MB * try_ctx / CTX_SIZE ))
        needed=$(( CPU_EXPERT_MB + kv_at_ctx + 5120 ))
        if (( needed <= RAM_AVAIL_MB )); then
            echo "WARNING: Reducing context from $CTX_SIZE to $try_ctx to fit in RAM"
            ACTUAL_CTX=$try_ctx
            # Rebuild COMMON_FLAGS with new context
            for idx in "${!COMMON_FLAGS[@]}"; do
                [[ "${COMMON_FLAGS[$idx]}" == "--ctx-size" ]] && COMMON_FLAGS[$((idx+1))]="$ACTUAL_CTX"
            done
            break
        fi
    done
fi

# Build -ot string
OT_ARGS=()
NEXT_LAYER=0
echo ""
echo "Expert placement (conservative):"
for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
    gi=${GPU_ORDER[$i]}
    layers=${LAYERS_PER_GPU[$gi]}
    if (( layers > 0 )); then
        OT_ARGS+=("${GPU_INDEX[$gi]}" "$NEXT_LAYER" "$layers")
        echo "  GPU${GPU_INDEX[$gi]} (${GPU_NAME[$gi]}): ${layers} layers (blk ${NEXT_LAYER}-$((NEXT_LAYER + layers - 1)))"
        NEXT_LAYER=$(( NEXT_LAYER + layers ))
    fi
done
echo "  CPU (RAM): ${LAYERS_CPU} layers (~${CPU_EXPERT_MB}MB)"

OT_STRING=$(build_ot_string "${OT_ARGS[@]}")

if (( DRY_RUN )); then
    print_cmd "${COMMON_FLAGS[@]}" --no-mmap -ot "$OT_STRING"
    exit 0
fi

# ── Auto-tuning loop ──
echo ""
echo "Starting server (conservative)..."
if try_start --no-mmap -ot "$OT_STRING"; then
    echo "  Server healthy (PID $RUNNING_PID)"
    sleep 2

    # Measure actual VRAM after load
    echo "  Measuring VRAM headroom..."
    declare -a ACTUAL_FREE
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        ACTUAL_FREE[$gi]=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits -i "${GPU_INDEX[$gi]}" 2>/dev/null | tr -d ' ')
        log "  GPU${GPU_INDEX[$gi]}: ${ACTUAL_FREE[$gi]}MB free after load"
    done

    # Calculate extra layers per GPU
    # IMPORTANT: ACTUAL_FREE doesn't include KV cache yet (allocated on first prompt)
    # Subtract current KV share per GPU before calculating extra capacity
    SAFETY_MB=512
    TOTAL_EXTRA=0
    declare -a EXTRA_PER_GPU
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        extra=0
        # Subtract KV cache that will be allocated for layers already on this GPU
        current_kv=$(( LAYERS_PER_GPU[$gi] * KV_PER_LAYER_MB ))
        usable_free=$(( ACTUAL_FREE[$gi] - current_kv - SAFETY_MB ))
        (( usable_free < 0 )) && usable_free=0
        if (( COST_PER_LAYER_MB > 0 )); then
            extra=$(( usable_free / COST_PER_LAYER_MB ))
        fi
        (( extra < 0 )) && extra=0
        EXTRA_PER_GPU[$gi]=$extra
        (( TOTAL_EXTRA += extra ))
    done

    # Apply extras (priority order), cap to remaining CPU layers
    if (( TOTAL_EXTRA > 0 && LAYERS_CPU > 0 )); then
        remaining_cpu=$LAYERS_CPU
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            gi=${GPU_ORDER[$i]}
            add=$(( EXTRA_PER_GPU[$gi] < remaining_cpu ? EXTRA_PER_GPU[$gi] : remaining_cpu ))
            LAYERS_PER_GPU[$gi]=$(( LAYERS_PER_GPU[$gi] + add ))
            remaining_cpu=$(( remaining_cpu - add ))
            (( remaining_cpu <= 0 )) && break
        done
        LAYERS_CPU=$remaining_cpu
        TOTAL_GPU_LAYERS=$(( LAYER_COUNT - LAYERS_CPU ))

        # Rebuild -ot string with optimized placement
        OT_ARGS=()
        NEXT_LAYER=0
        echo ""
        echo "Optimized placement:"
        for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
            gi=${GPU_ORDER[$i]}
            layers=${LAYERS_PER_GPU[$gi]}
            if (( layers > 0 )); then
                OT_ARGS+=("${GPU_INDEX[$gi]}" "$NEXT_LAYER" "$layers")
                echo "  GPU${GPU_INDEX[$gi]} (${GPU_NAME[$gi]}): ${layers} layers (blk ${NEXT_LAYER}-$((NEXT_LAYER + layers - 1)))"
                NEXT_LAYER=$(( NEXT_LAYER + layers ))
            fi
        done
        echo "  CPU (RAM): ${LAYERS_CPU} layers"

        OT_STRING=$(build_ot_string "${OT_ARGS[@]}")

        # Restart with optimized config
        kill_server "$RUNNING_PID"
        echo ""
        echo "Restarting with optimized config..."
        if ! try_start --no-mmap -ot "$OT_STRING"; then
            echo "  Optimized config failed — falling back..."
            # Reduce by 1 layer on primary GPU
            primary=${GPU_ORDER[0]}
            LAYERS_PER_GPU[$primary]=$(( LAYERS_PER_GPU[$primary] - 1 ))
            LAYERS_CPU=$(( LAYERS_CPU + 1 ))

            OT_ARGS=()
            NEXT_LAYER=0
            for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
                gi=${GPU_ORDER[$i]}
                layers=${LAYERS_PER_GPU[$gi]}
                if (( layers > 0 )); then
                    OT_ARGS+=("${GPU_INDEX[$gi]}" "$NEXT_LAYER" "$layers")
                    NEXT_LAYER=$(( NEXT_LAYER + layers ))
                fi
            done
            OT_STRING=$(build_ot_string "${OT_ARGS[@]}")
            kill_server ""
            if ! try_start --no-mmap -ot "$OT_STRING"; then
                echo "FAILED: Could not start server. Check $SERVER_LOG"
                suggest_alternatives "$VRAM_NEEDED_MB" "$(( TOTAL_VRAM_MB + RAM_AVAIL_MB ))"
                exit 1
            fi
        fi
    else
        echo "  Conservative config is already optimal (GPUs full)"
    fi

    # Save to cache
    CACHED_GPU_ASSIGNMENTS=""
    NEXT_LAYER=0
    for i in $(seq 0 $(( GPU_COUNT - 1 ))); do
        gi=${GPU_ORDER[$i]}
        layers=${LAYERS_PER_GPU[$gi]}
        if (( layers > 0 )); then
            CACHED_GPU_ASSIGNMENTS+="${GPU_INDEX[$gi]}:${NEXT_LAYER}:${layers} "
            NEXT_LAYER=$(( NEXT_LAYER + layers ))
        fi
    done

    cat > "$CACHE_FILE" <<CEOF
# Auto-tuned config for $MODEL_NAME
# Generated: $(date)
# Total layers: $LAYER_COUNT, Experts: $EXPERT_COUNT
CACHED_GPU_ASSIGNMENTS="$CACHED_GPU_ASSIGNMENTS"
CEOF

    TOTAL_GPU_LAYERS=$(( LAYER_COUNT - LAYERS_CPU ))
    echo ""
    echo "═══════════════════════════════════════════"
    echo "  Model: $MODEL_NAME"
    echo "  Size: ${TOTAL_SIZE_GB}GB | Layers: $LAYER_COUNT | Experts: $EXPERT_COUNT"
    echo "  GPU layers: $TOTAL_GPU_LAYERS | CPU layers: $LAYERS_CPU"
    echo "  Context: $ACTUAL_CTX | Port: $PORT"
    echo "  Config cached: $CACHE_FILE"
    echo "═══════════════════════════════════════════"

    # Kill the tuning server, restart via the crash-safe loop
    kill_server "$RUNNING_PID"
    run_with_restart "${COMMON_FLAGS[@]}" --no-mmap -ot "$OT_STRING"
else
    echo "FAILED: Could not start server even with conservative config."
    echo "Check $SERVER_LOG for details."
    tail -20 "$SERVER_LOG" 2>/dev/null
    suggest_alternatives "$VRAM_NEEDED_MB" "$(( TOTAL_VRAM_MB + RAM_AVAIL_MB ))"
    exit 1
fi
